+
+- (void)addViewSucceeded:(NSString *)viewName viewInfoName:(NSString *)viewInfoName
+{
+  if (![viewName isEqualToString:OnreoriMapViewName]) {
+    return;
+  }
+
+  _mapReady = YES;
+  self.map.eventDelegate = self;
+  self.map.viewRect = self.bounds;
+  [self refreshMarkers];
+  [self moveMapToCurrentCenter];
+}
+
+- (void)addViewFailed:(NSString *)viewName viewInfoName:(NSString *)viewInfoName
+{
