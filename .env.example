SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-public-anon-or-publishable-key

# Comma-separated allowlist for event URL preview hosts. Supports exact hosts
# and wildcard subdomains such as "*.example.com". Empty means deny all.
EVENT_URL_PREVIEW_ALLOWED_HOSTS=events.example.com,*.example.org

# Native Kakao Maps builds require this value.
# Use the Native app key from Kakao Developers, not the JavaScript or REST API key.
# Android: export KAKAO_NATIVE_APP_KEY or pass -PKAKAO_NATIVE_APP_KEY=...
# iOS: pass KAKAO_NATIVE_APP_KEY=... to xcodebuild or use ios/Config/KakaoMap.local.xcconfig.
# The iOS platform in Kakao Developers must also register the app bundle id.
# Check ios/onreori.xcodeproj PRODUCT_BUNDLE_IDENTIFIER when Kakao Maps returns 401.
KAKAO_NATIVE_APP_KEY=
